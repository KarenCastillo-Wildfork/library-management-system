# For running this service standalone (outside docker-compose), e.g. via
# `mvn spring-boot:run`, with a local Postgres on port 5433.
SERVER_PORT=8080
DB_URL=jdbc:postgresql://localhost:5433/library_db
DB_USERNAME=library_user
DB_PASSWORD=library_pass
JWT_SECRET=change-this-super-secret-key-in-prod-please-0123456789
JWT_EXPIRATION_MS=3600000
INTERNAL_API_KEY=change-this-internal-key
SERVICE_B_URL=http://localhost:8081
SERVICE_B_TIMEOUT_MS=5000
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@library.local
ADMIN_PASSWORD=Admin123!
