# Copy this file to .env and adjust values before running `docker compose up`.
# .env is gitignored - never commit real secrets.

# --- Shared secret between Service A and Service B for the internal
# /internal/books/{id}/availability call. Must be identical on both sides. ---
INTERNAL_API_KEY=change-this-internal-key

# --- Service A: JWT signing secret (HMAC-SHA256, keep it long and random) ---
JWT_SECRET=change-this-super-secret-key-in-prod-please-0123456789

# --- Service A: initial ADMIN account, created on first startup ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@library.local
ADMIN_PASSWORD=Admin123!

# --- Service A's database (postgres-library) ---
DB_LIBRARY_USER=library_user
DB_LIBRARY_PASSWORD=library_pass
DB_LIBRARY_NAME=library_db

# --- Service B's database (postgres-loans) ---
DB_LOANS_USER=loans_user
DB_LOANS_PASSWORD=loans_pass
DB_LOANS_NAME=loans_db
