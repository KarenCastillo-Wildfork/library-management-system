# For running this service standalone (outside docker-compose), e.g. via
# `go run ./cmd/server`, with a local Postgres on port 5434.
SERVER_PORT=8081
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=loans_user
DB_PASSWORD=loans_pass
DB_NAME=loans_db
LIBRARY_SERVICE_URL=http://localhost:8080
INTERNAL_API_KEY=change-this-internal-key
LIBRARY_SERVICE_TIMEOUT_MS=5000
LOAN_PERIOD_DAYS=14
